{
  "name": "@dashx/browser",
  "title": "dashx-browser",
  "version": "0.8.2",
  "description": "DashX SDK for Browser",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    },
    "./sw": {
      "types": "./dist/src/sw-helper.d.ts",
      "import": "./dist/sw-helper.es.js",
      "require": "./dist/sw-helper.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "yarn typecheck && vite build && BUILD_TARGET=sw vite build",
    "preview": "vite preview",
    "codegen": "graphql-codegen && eslint --fix ./src/generated",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dashxhq/dashx-browser"
  },
  "keywords": [
    "dashx"
  ],
  "license": "MIT",
  "dependencies": {
    "@apollo/client": "^4.2.2",
    "@graphql-typed-document-node/core": "^3.2.0",
    "ajv": "^8.20.0",
    "graphql": "^16.14.1",
    "rxjs": "^7.8.2",
    "uuid-random": "^1.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/add": "^5.0.0",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typed-document-node": "^5.0.0",
    "@graphql-codegen/typescript-operations": "^4.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-plugin-import": "^2.32.0",
    "graphql-codegen-typescript-operation-types": "^2.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  }
}
